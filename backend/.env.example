# Backend configuration
APP_NAME="Product Video Factory API"
# Comma-separated list of allowed CORS origins (the frontend dev server)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Directory where uploaded media and rendered videos are stored
STORAGE_DIR="storage"
# Which generation engine to use: "stub" (simulated) or "moneyprinterturbo"
VIDEO_ENGINE="stub"
# Base URL of a running MoneyPrinterTurbo API instance (only used when VIDEO_ENGINE=moneyprinterturbo)
MPT_BASE_URL="http://localhost:8080"
