# Backend configuration
APP_NAME="Product Video Factory API"
# Comma-separated list of allowed CORS origins (the frontend dev server)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Directory where uploaded media and rendered videos are stored
STORAGE_DIR="storage"

# Which generation engine to use:
#   stub              — simulated pipeline (no external services)
#   moneyprinterturbo — real renders via MoneyPrinterTurbo API
VIDEO_ENGINE="moneyprinterturbo"

# Base URL of a running MoneyPrinterTurbo API instance.
# Default when MPT runs via Docker: http://127.0.0.1:8080
MPT_BASE_URL="http://127.0.0.1:8080"

# -----------------------------------------------------------------------------
# API keys for LLM / stock footage do NOT go here.
# Configure them in MoneyPrinterTurbo's config.toml instead:
#   backend/MoneyPrinterTurbo/config.toml
# See docs/MONEYPRINTERTURBO_SETUP.md in this repo.
# -----------------------------------------------------------------------------
